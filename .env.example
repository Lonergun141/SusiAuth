# Copy to .env and adjust. Loaded by config/settings/base.py.
# Do NOT commit your real .env (it is gitignored).

# --- Django ------------------------------------------------------------------
DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# --- Database (PostgreSQL) ---------------------------------------------------
# For local (non-Docker) runs use localhost. docker-compose overrides DB_HOST
# to the "db" service automatically, so this value only matters off-Docker.
DB_NAME=authdb
DB_USER=authuser
DB_PASSWORD=authpass
DB_HOST=localhost
DB_PORT=5432

# --- Email -------------------------------------------------------------------
# EMAIL_PROVIDER: console (dev, prints to terminal) | resend (real delivery via
# Anymail). Local dev defaults to console, so Resend creds are optional locally.
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=no-reply@susiauth.local

# Resend (required when EMAIL_PROVIDER=resend). Get keys from
# https://resend.com/api-keys ; the webhook secret from the webhook settings.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@susiauth.local
RESEND_WEBHOOK_SECRET=

# Celery: run email tasks inline (no broker) in dev/test; set a broker in prod.
CELERY_TASK_ALWAYS_EAGER=1
# CELERY_BROKER_URL=redis://localhost:6379/0
# Shared Django cache / rate limiting. Compose overrides the hostname to `redis`.
REDIS_CACHE_URL=redis://localhost:6379/1

# --- JWT ---------------------------------------------------------------------
JWT_ISSUER=auth-service
JWT_AUDIENCE=your-apps
JWT_ACCESS_TTL_SECONDS=600
JWT_REFRESH_TTL_SECONDS=2592000
OTP_TTL_MINUTES=5
ONETIMETOKEN_TTL_MINUTES=15
# Defaults resolve to <repo>/keys/jwt_private.pem and jwt_public.pem.
# JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# --- Frontend links embedded in emails --------------------------------------
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password?token={token}
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3000/verify-email?token={token}
